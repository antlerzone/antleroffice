{
  "name": "antleroffice2",
  "productName": "AntlerOffice",
  "main": "electron/main.cjs",
  "private": true,
  "version": "2.0.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "node --watch --env-file=.env server/index.js",
    "dev:server:clean": "node scripts/kill-port.cjs 3020 8766 8767 8931 && node --watch --env-file=.env server/index.js",
    "dev:all": "concurrently -n \"frontend,backend\" -c \"blue,green\" \"vite\" \"node --watch --env-file=.env server/index.js\"",
    "dev:chrome": "node scripts/kill-antleroffice-dev-ports.cjs && concurrently -n \"frontend,backend\" -c \"blue,green\" \"vite\" \"node --watch --env-file=.env server/index.js\"",
    "dev:electron": "node scripts/kill-antleroffice-dev-ports.cjs && concurrently -n \"frontend,backend,electron\" -c \"blue,green,magenta\" \"vite\" \"node --watch --env-file=.env server/index.js\" \"node scripts/wait-for-dev.cjs && cross-env ELECTRON_DEV=1 electron .\"",
    "build": "vue-tsc -b && vite build",
    "build:app": "vite build",
    "build:icon": "node scripts/generate-icon.cjs",
    "installer:postinstall": "node scripts/installer-postinstall.cjs",
    "build:win": "npm run build:icon && npm run build:app && node scripts/strip-optional-natives.cjs && electron-builder --win --x64",
    "postinstall": "electron-builder install-app-deps",
    "preview": "vite preview",
    "start": "node --env-file=.env server/index.js",
    "electron": "electron .",
    "verify:plan1": "node server/antler/verify-plan1.js",
    "verify:plan234": "node server/antler/verify-plan234.js",
    "verify:standup": "node server/antler/verify-standup.js"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@noble/ed25519": "^3.0.0",
    "@types/katex": "^0.16.8",
    "@vicons/ionicons5": "^0.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.9.0",
    "check-disk-space": "^3.4.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "edge-tts-client": "^1.0.2",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "katex": "^0.16.44",
    "markdown-it": "^14.1.1",
    "multer": "^2.0.2",
    "naive-ui": "^2.43.2",
    "node-cron": "^4.4.1",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^3.11.174",
    "pdfkit": "^0.19.1",
    "@xenova/transformers": "^2.17.2",
    "patchright": "^1.61.1",
    "pinia": "^3.0.4",
    "playwright": "^1.58.2",
    "ssh2": "^1.17.0",
    "tar": "^7.5.11",
    "unzipper": "^0.12.3",
    "uuid": "^13.0.0",
    "vue": "^3.5.25",
    "vue-i18n": "^9.0.0",
    "vue-pdf-embed": "^2.1.4",
    "vue-router": "^4.6.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8",
    "electron-updater": "^6.8.9",
    "esbuild": "^0.28.0",
    "eventsource": "^4.1.0",
    "happy-dom": "^20.7.0",
    "png-to-ico": "^3.0.1",
    "prebuild-install": "^7.1.2",
    "sharp": "^0.35.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^4.0.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.5"
  },
  "build": {
    "appId": "com.antlerzone.antleroffice",
    "productName": "AntlerOffice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "server/**/*",
      "electron/**/*",
      "public/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**"
    ],
    "extraResources": [
      {
        "from": "server/voice-sidecar",
        "to": "voice-sidecar",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/antleroffice-logo-black.png",
      "artifactName": "AntlerOffice-Setup-${version}-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AntlerOffice"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "antlerzone",
        "repo": "antleroffice"
      }
    ]
  }
}
