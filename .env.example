VITE_APP_TITLE=AntlerOffice
OPENCLAW_WS_URL=ws://localhost:18789
OPENCLAW_AUTH_TOKEN=1212
OPENCLAW_AUTH_PASSWORD=
PORT=3020
DEV_PORT=3300
# Do NOT use 3001 — reserved for Coliving Portal (portal.colivingjb.com) on this machine.
# Optional: set when building the Windows .exe so ECS URLs are written on first launch
# ANTLEROFFICE_PACKAGED=1
# ECS official API — run Antlermarket/server on :3030 locally (only when NOT using cloud login below)
# ECS_BASE_URL=http://localhost:3030
# Browser login + register on production website (OAuth opens office.antlerzone.com even in Chrome dev)
VITE_OFFICE_WEB_URL=https://office.antlerzone.com
# Verify desktop/portal tokens (must match where VITE_OFFICE_WEB_URL login issues tokens)
ECS_AUTH_URL=https://office.antlerzone.com
# Optional: portal-auth API (Google/Facebook); defaults to api.antlerzone.com in dev popup flows
# VITE_PORTAL_AUTH_API_URL=https://api.antlerzone.com
# HR create_saas_worker MCP → same server admin API (optional in local dev)
# ECS_ADMIN_TOKEN=dev-local-admin
# ANTLEROFFICE_AUTH_MOCK=1
# Optional: encrypt web account secrets (passwords/cookies). If unset, a local key is auto-generated in ~/.antleroffice2/.master-key
# ANTLEROFFICE_SECRET_KEY=
# Per-install data directory (settings, notes, default materials folder, etc.)
# ANTLEROFFICE_DATA_DIR=
# Optional override for the default materials library folder (auto-created on first launch)
# ANTLEROFFICE_MATERIALS_DIR=
# ECS_OAUTH_CLIENT_ID=antleroffice-desktop
# ECS_OAUTH_REDIRECT_URI=http://127.0.0.1:3020/api/boss/auth/oauth/callback
AUTH_USERNAME=admin
AUTH_PASSWORD=admin
LOG_LEVEL=INFO
#OPENCLAW_HOME=/home/ubuntu

# Hermes Agent Configuration
HERMES_WEB_URL=http://localhost:9119
HERMES_API_URL=http://localhost:8642
HERMES_API_KEY=hermes-local-dev-key

# TTS (Text-to-Speech) Configuration
VITE_TTS_ENABLED=true
VITE_TTS_AUTO_PLAY=false
VITE_TTS_VOICE=zh-CN
VITE_TTS_RATE=1.0
VITE_TTS_VOLUME=1.0
VITE_TTS_PITCH=1.0

# Voice clone (local CosyVoice sidecar)
# VOICE_TTS_URL=http://127.0.0.1:8765
# COSYVOICE_MODEL=FunAudioLLM/Fun-CosyVoice3-0.5B-2512
# VOICE_TTS_MIN_VRAM_MB=6144

# Voice STT/TTS reuses the OpenAI key from onboarding / OpenClaw auth (Settings → Models).
# Optional per-user voice override: Settings → Summon → Voice API.
# VOICE_TYPEWHISPER_URL=http://127.0.0.1:8978
# VOICE_TRANSCRIBE_URL=http://127.0.0.1:3020/api/voice/transcribe

# Instagram tool (ig-mcp) → bound to the Admin role. See vendor/ig-mcp/配置说明-中文.md
# Requires Python 3.10+ : pip install -r vendor/ig-mcp/requirements.txt
# INSTAGRAM_ACCESS_TOKEN=
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Optional overrides:
# ANTLEROFFICE_PYTHON=python
# ANTLEROFFICE_IG_MCP_PATH=

# Marketing Junior → built-in Playwright FB engine (no external poster service)
# First run: cd AntlerOffice2 && npx playwright install chrome
# Partner portal OAuth (Coliving / AntlerChat / AntlerHub) — hire VIP workers
# PORTAL_OAUTH_FRONTEND=http://127.0.0.1:3300
# COLIVING_ECS_BASE_URL=https://api.colivingjb.com
# ANTLERCHAT_ECS_BASE_URL=https://api.antlerzone.com
# ANTLERHUB_ECS_BASE_URL=https://api.antlerzone.com