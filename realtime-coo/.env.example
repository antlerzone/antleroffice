# 复制成 .env 再填。这个文件夹和主项目分开，自己一套配置。

# OpenAI Key：默认自动读 AntlerOffice（model 设置页）里设好的那个，这里不用填。
# 只有当 AntlerOffice 里没设、想单独给新版用别的 key 时，才填这一行。
# OPENAI_API_KEY=sk-xxxxx

# Realtime 模型（官方 GA 名字，按需改）
REALTIME_MODEL=gpt-realtime

# Realtime 用哪个声音（OpenAI 自带音色：alloy / verse / cedar 等）
REALTIME_VOICE=cedar

# 网页 + 令牌 + COO本地中转，监听的端口（浏览器打开 http://127.0.0.1:8940）
APP_PORT=8940

# ↓↓↓ 下面这些是“远程 MCP”模式才用的，本地中转模式不用管 ↓↓↓
# MCP_PORT=8941
# MCP_PUBLIC_URL=https://YOUR-TUNNEL.trycloudflare.com/mcp

# ---- 接到现有 COO/OpenClaw ----
# 新版复用主项目里那条已经写好的 COO 接线（openclaw-gateway-chat）。
# 默认会自动找 ../../server/antler/runtime/openclaw-gateway-chat，一般不用改。
# COO_GATEWAY_CHAT_PATH=
